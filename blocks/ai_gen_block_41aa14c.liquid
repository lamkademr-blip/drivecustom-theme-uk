        {
          "value": "text_image",
          "label": "Text left, image right"
        }
      ],
      "default": "image_text"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Spacing between image and text",
      "default": 40
