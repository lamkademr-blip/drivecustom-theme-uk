{% comment %}
  Animated and modernized FAQ section for product pages
  Dawn Theme - Drive Custom
{% endcomment %}

{% schema %}
{
  "name": "Product FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Frequently asked questions",
      "label": "Section heading"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#2C5364"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "default": "<p>Answer to the question</p>",
          "label": "Answer",
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "title": "Airbag - Is the steering wheel compatible with the original airbag system?",
            "answer": "<p>No, our custom steering wheels are not compatible with the original airbag system. They are designed to completely replace the original unit. Please note that removing the airbag system may affect your vehicle's compliance with road safety standards. For this reason, we recommend checking the legislation in force in your country.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "title": "Approval - Is this steering wheel road-legal?",
            "answer": "<p>Yes, all our steering wheels are approved for road use. They comply with current standards and regulations for legal use on public roads. Each steering wheel comes with its approval certificate which you can present if checked. Our priority is to offer you products that are both aesthetic and compliant with legal requirements.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "title": "Delivery - What are the delivery times and costs?",
            "answer": "<p><strong>A custom steering wheel takes between 3 and 5 weeks to be crafted and delivered worldwide.</strong> The artisanal manufacturing and attention to every detail require this timeframe to guarantee impeccable quality. Shipping is free for all orders, regardless of destination country. Each steering wheel is carefully packaged to ensure optimal protection during transport.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "title": "Warranty - What is the exact warranty period and what does it cover?",
            "answer": "<p>All our steering wheels come with a 5-year warranty against manufacturing defects. This warranty covers issues related to the steering wheel structure, stitching, materials, and finishes. It does not cover normal wear and tear, damage due to misuse, accidents, or modifications made to the product. In the event of a problem covered by the warranty, we will repair or replace the steering wheel at our discretion.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "title": "Installation - Does installation require specific technical skills?",
            "answer": "<p>Installing our steering wheels requires basic knowledge of automotive mechanics and some specific tools. Although the procedure is not extremely complex, we recommend using a professional to ensure a correct and safe installation. Each steering wheel comes with a detailed installation guide. For some vehicle models, specific adapters may be required (not included) - feel free to contact us to check compatibility with your vehicle.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<div class="page-width isolate product-faq-section-modern">
  <div class="product-faq-title-modern">
    {{ section.settings.heading }}
  </div>
  <div class="product-faq-container-modern">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'faq' %}
          <details class="faq-item-modern">
            <summary class="faq-question-modern">
              <span>{{ block.settings.title }}</span>
              <span class="faq-icon-modern">
                <!-- Chevron SVG -->
                <svg width="22" height="22" viewBox="0 0 20 20" fill="none">
                  <path d="M6 8L10 12L14 8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
            </summary>
            <div class="faq-answer-modern">
              {{ block.settings.answer }}
            </div>
          </details>
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% assign accent_color = section.settings.accent_color %}
{% assign text_color = section.settings.text_color %}
{% assign bg_color = section.settings.background %}

<style>
  .product-faq-section-modern {
    padding: 50px 0 20px 0;
    background: {{ bg_color }};
  }
  .product-faq-title-modern {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 35px;
    color: {{ text_color }};
    position: relative;
    letter-spacing: -.5px;
  }
  .product-faq-title-modern:after {
    content: '';
    position: absolute;
    bottom: -13px;
    left: 50%;
    transform: translateX(-50%);
    width: 70px;
    height: 3.5px;
    background: linear-gradient(90deg, {{ accent_color }}, #35a3ff 80%);
    border-radius: 2.5px;
  }
  .product-faq-container-modern {
    max-width: 750px;
    margin: 0 auto;
  }
  .faq-item-modern {
    background: #fff;
    border-radius: 18px;
    margin-bottom: 20px;
    box-shadow: 0 6px 32px -10px rgba(44,83,100,0.09);
    transition: box-shadow .2s, border-color .3s;
    border: 1.5px solid #f1f4f7;
    overflow: hidden;
  }
  .faq-item-modern[open] {
    box-shadow: 0 12px 38px -10px rgba(44,83,100,0.17);
    border-color: {{ accent_color }};
  }
  .faq-question-modern {
    padding: clamp(18px, 4vw, 26px);
    cursor: pointer;
    font-weight: 600;
    font-size: clamp(1.07rem, 2.2vw, 1.24rem);
    color: {{ text_color }};
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: none;
    transition: background .13s;
    outline: none;
    border: none;
    list-style: none;
    user-select: none;
  }
  .faq-item-modern:hover .faq-question-modern,
  .faq-question-modern:focus {
    background: rgba(44, 83, 100, 0.035);
  }
  .faq-icon-modern {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: 14px;
    transition: transform .3s cubic-bezier(.45,1.5,.75,1.1), color .3s;
    color: {{ accent_color }};
  }
  .faq-item-modern[open] .faq-icon-modern {
    transform: rotate(180deg) scale(1.15);
    color: #35a3ff;
  }
  .faq-answer-modern {
    font-size: clamp(0.98rem, 2vw, 1.13rem);
    padding: clamp(13px, 3vw, 24px) clamp(10px, 3vw, 26px) clamp(17px, 4vw, 24px) clamp(10px, 3vw, 26px);
    color: #516070;
    background: #fafdff;
    border-top: 1px solid #eef1f6;
    animation: faqFadeIn .45s;
    line-height: 1.7;
    border-radius: 0 0 18px 18px;
  }
  .faq-answer-modern p { margin-top: 0; margin-bottom: 0; }
  .faq-answer-modern strong { color: {{ accent_color }}; }
  @keyframes faqFadeIn {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (max-width: 749px) {
    .product-faq-section-modern { padding: 30px 0 5px 0; }
    .product-faq-title-modern { font-size: clamp(1.19rem, 4.2vw, 1.7rem); margin-bottom: 21px; }
    .product-faq-title-modern:after { width: 40px; height: 2.2px; bottom: -6px; }
    .product-faq-container-modern { padding: 0 3vw; }
    .faq-question-modern { font-size: clamp(0.99rem, 3.5vw, 1.11rem); }
    .faq-answer-modern { font-size: clamp(0.92rem, 3vw, 1.05rem);}
    .faq-item-modern { margin-bottom: 14px; border-radius: 10px;}
    .faq-answer-modern { border-radius: 0 0 10px 10px; }
  }
  /* Hides ghost slider arrows that might remain after the FAQ */
  .product-faq-section-modern + .slider-buttons,
  .product-faq-section-modern + .slider-button {
    display: none !important;
  }
</style>
