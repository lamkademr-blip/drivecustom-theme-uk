{% schema %}
{
  "name": "Scrolling banner",
  "settings": [
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Scroll speed",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "reverse_direction",
      "label": "Reverse direction",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "banner_item",
      "name": "Banner item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Eco-friendly"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling banner",
      "blocks": [
        {
          "type": "banner_item",
          "settings": {
            "text": "Eco-friendly"
          }
        },
        {
          "type": "banner_item",
          "settings": {
            "text": "Cost-effective"
          }
        },
        {
          "type": "banner_item",
          "settings": {
            "text": "Hygienic"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .scrolling-banner {
    width: 100%;
    overflow: hidden;
    background: linear-gradient(to right, #1A2141, #4E5988);
    padding: 6px 0; /* Compact height */
  }

  .banner-content {
    display: flex;
    white-space: nowrap;
  }

  .banner-item {
    display: inline-flex;
    align-items: center;
    margin: 0 15px; /* Reduced spacing */
    color: {{ section.settings.text_color }};
    font-weight: 600;
    font-size: 14px; /* Smaller text */
    flex-shrink: 0;
  }

  .banner-icon {
    width: 20px; /* Slightly smaller icons */
    height: 20px;
    margin-right: 6px;
    object-fit: contain;
  }
</style>

<div class="scrolling-banner">
  <div class="banner-content" id="bannerContent">
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        {% if block.type == "banner_item" %}
          <div class="banner-item">
            {% if block.settings.icon %}
              <img src="{{ block.settings.icon | img_url: '50x50', crop: 'center' }}" class="banner-icon" alt="">
            {% endif %}
            {{ block.settings.text }}
          </div>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const bannerContent = document.getElementById('bannerContent');
  let speed = {{ section.settings.scroll_speed }};
  let direction = {{ section.settings.reverse_direction | json }} ? 1 : -1;

  function animateBanner() {
    const contentWidth = bannerContent.scrollWidth / 2;
    let progress = 0;

    function step() {
      progress += direction * (contentWidth / (speed * 60));
      if (direction === -1 && Math.abs(progress) >= contentWidth) {
        progress = 0;
      } else if (direction === 1 && progress >= 0) {
        progress = -contentWidth;
      }
      bannerContent.style.transform = `translateX(${progress}px)`;
      requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  animateBanner();
});
</script>
